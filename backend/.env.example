# Backend Environment Variables Example
# Copy to .env.local and modify as needed

# Database
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=rootpassword
DATABASE_NAME=opc_aicom

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRE_HOURS=24

# Matrix Configuration (for external server)
# Leave empty to use config.yaml defaults (localhost:8008)
MATRIX_HOMESERVER_URL=http://localhost:8008
MATRIX_SERVER_NAME=localhost
MATRIX_SHARED_SECRET=mysecret
MATRIX_ADMIN_API_URL=http://localhost:8008/_matrix/admin

# For external Matrix server:
# MATRIX_HOMESERVER_URL=http://8.217.143.228:8008
# MATRIX_SERVER_NAME=8.217.143.228
# MATRIX_SHARED_SECRET=your-external-secret

# LLM
OPENAI_API_KEY=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
