# ========================================
# E2E测试环境配置 - 百度千帆LLM
# ========================================

# 百度千帆 OpenAI兼容接口配置
# 获取API Key: https://console.bce.baidu.com/qianfan/
OPENAI_API_KEY=your-qianfan-api-key-here

# 百度千帆 OpenAI兼容端点
OPENAI_BASE_URL=https://qianfan.baidubce.com/v2/llm/openai/v1

# 默认LLM Provider
LLM_DEFAULT_PROVIDER=openai

# ----------------------------------------
# 数据库配置（通常使用默认值）
# ----------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_USER=opc_user
DB_PASSWORD=opcpassword
DB_NAME=opc_aicom

# ----------------------------------------
# Matrix配置（通常使用默认值）
# ----------------------------------------
MATRIX_HOMESERVER=http://localhost:8008
MATRIX_SERVER_NAME=localhost

# ----------------------------------------
# JWT配置（测试环境固定密钥）
# ----------------------------------------
JWT_SECRET=e2e-test-secret-key-do-not-use-in-production
JWT_EXPIRY=86400

# ----------------------------------------
# 服务配置
# ----------------------------------------
SERVER_PORT=8080
GIN_MODE=debug
